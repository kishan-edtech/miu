  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=windows-1252">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Roboto:ital,wght@0,500;0,700;1,500;1,700&display=swap" rel="stylesheet">
    <?php
      error_reporting(0);
      require '../../includes/db-config.php';
      $id = mysqli_real_escape_string($conn, $_GET['student_id']);
      $id = base64_decode($id);
      $student_id = intval(str_replace('W1Ebt1IhGN3ZOLplom9I', '', $id));
      $get_record = $conn->query("SELECT Students.*, CONCAT(Students.First_Name, ' ', Students.Middle_Name, ' ', Students.Last_Name) as StudentName, RIGHT(CONCAT('000000', Students.ID), 6) as Student_ID, Admission_Sessions.Name as Session, Courses.Name as Course, Courses.Short_Name as Short_Name, Sub_Courses.Name as Sub_Course FROM Students LEFT JOIN Admission_Sessions ON Students.Admission_Session_ID = Admission_Sessions.ID LEFT JOIN Courses ON Students.Course_ID = Courses.ID LEFT JOIN Sub_Courses ON Students.Sub_Course_ID = Sub_Courses.ID WHERE Students.ID = $student_id");
      $st = mysqli_fetch_assoc($get_record);
      $photo = $conn->query("SELECT Location FROM Student_Documents WHERE Student_ID = ".$st['ID']." AND Type = 'Photo'");
      $photo = $photo->fetch_assoc();
      $photo = $photo['Location'];
      $signature = $conn->query("SELECT Location FROM Student_Documents WHERE Student_ID = ".$st['ID']." AND Type = 'Student Signature'");
      $signature = $signature->fetch_assoc();
      $signature = $signature['Location'];
      $address = json_decode($st['Address'], true);

      $high_school = $conn->query("SELECT * FROM Student_Academics WHERE Student_ID = ".$st['ID']." AND Type = 'High School'");
      $high_school = $high_school->fetch_assoc();

      $intermediate = $conn->query("SELECT * FROM Student_Academics WHERE Student_ID = ".$st['ID']." AND Type = 'Intermediate'");
      $intermediate = $intermediate->fetch_assoc();

      $ug = $conn->query("SELECT * FROM Student_Academics WHERE Student_ID = ".$st['ID']." AND Type = 'UG'");
      $ug = $ug->fetch_assoc();

      $pg = $conn->query("SELECT * FROM Student_Academics WHERE Student_ID = ".$st['ID']." AND Type = 'PG'");
      $pg = $pg->fetch_assoc();

      $other = $conn->query("SELECT * FROM Student_Academics WHERE Student_ID = ".$st['ID']." AND Type = 'Other'");
      $other = $other->fetch_assoc();
    ?>
